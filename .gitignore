# Ralph generated files (inside .ralph/ subfolder)
.ralph/.call_count
.ralph/.last_reset
.ralph/.exit_signals
.ralph/status.json
.ralph/.ralph_session
.ralph/.ralph_session_history
.ralph/.claude_session_id
.ralph/.response_analysis
.ralph/.circuit_breaker_state
.ralph/.circuit_breaker_history

# Ralph logs and generated docs
.ralph/logs/*
!.ralph/logs/.gitkeep
.ralph/docs/generated/*
!.ralph/docs/generated/.gitkeep

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Ralph backup directories (created by migration)
.ralph_backup_*

# Next.js build output
.next/

# TypeScript incremental build cache
tsconfig.tsbuildinfo

# Vendored reference source (not committed)
claude-code-source/

# Python package metadata (regenerated by pip install -e)
*.egg-info/

# Playwright test artifacts
test-results/
.playwright-mcp/

# Hardening-round audit artifacts (screenshots, intermediate notes)
.audit/

# Ad-hoc screenshots dropped at repo root by interactive iteration sessions.
# Move anything you want to keep into docs/ or screenshots/.
/*.png

# Claude Code project state (per-machine)
.claude/

# SkillNote per-project state (per-machine; pins active collection)
.skillnote.json
.skillnote/
