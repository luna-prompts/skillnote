#!/usr/bin/env python3
"""SkillNote status line for Claude Code."""
import json
import os
import sys

data = json.load(sys.stdin)

# Resolve host
host = os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "")
if not host:
    host_file = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(host_file):
        try:
            with open(host_file) as f:
                host = f.read().strip()
        except Exception:
            pass
host = host or "localhost"
web_url = f"http://{host}:3000"

# Read active collection
project_dir = data.get("workspace", {}).get("current_dir", ".")
config_path = os.path.join(project_dir, ".skillnote.json")
collection = ""
if os.path.isfile(config_path):
    try:
        with open(config_path) as f:
            cfg = json.load(f)
        cols = cfg.get("collections", [])
        if cols:
            collection = cols[0]
    except Exception:
        pass

# Count synced skills
skills_dir = os.path.join(project_dir, ".claude", "skills")
skill_count = 0
skill_names = []
if os.path.isdir(skills_dir):
    skill_names = sorted([d for d in os.listdir(skills_dir)
                          if os.path.isdir(os.path.join(skills_dir, d))])
    skill_count = len(skill_names)

# Colors
CYAN = "\033[36m"
GREEN = "\033[32m"
DIM = "\033[2m"
BOLD = "\033[1m"
RESET = "\033[0m"

# Build status
parts = []

# Branding
parts.append(f"{CYAN}{BOLD}SkillNote{RESET}")

# Collection + skills
if collection:
    parts.append(f"{collection} {DIM}({skill_count} skills){RESET}")
else:
    parts.append(f"{DIM}no collection{RESET}")

# Web URL as clickable link
parts.append(f"\033]8;;{web_url}\a{DIM}{web_url}{RESET}\033]8;;\a")

print(" │ ".join(parts))
