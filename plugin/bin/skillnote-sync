#!/bin/bash
# SkillNote Sync — CLI wrapper
# Available as a bare command in Claude Code Bash tool.
# Usage: skillnote-sync [--force]

PROJECT_DIR="${CLAUDE_PROJECT_DIR:-.}"
[ ! -f "$PROJECT_DIR/.skillnote.json" ] && { echo "No .skillnote.json — pick a collection first."; exit 0; }

if [ "$1" = "--force" ]; then
    # Force re-sync by removing manifest AND all managed skill dirs
    SKILLS_DIR="$PROJECT_DIR/.claude/skills"
    MANIFEST="$SKILLS_DIR/.skillnote-manifest.json"
    if [ -n "$CLAUDE_PLUGIN_DATA" ]; then
        MANIFEST="$CLAUDE_PLUGIN_DATA/.skillnote-manifest.json"
    fi
    if [ -f "$MANIFEST" ]; then
        python3 -c "
import json, os, shutil, sys
m = json.load(open(sys.argv[1]))
sd = sys.argv[2]
for slug in m.get('skills', []):
    d = os.path.join(sd, slug)
    if os.path.isdir(d):
        shutil.rmtree(d)
" "$MANIFEST" "$SKILLS_DIR" 2>/dev/null
    fi
    rm -f "$MANIFEST"
fi

# Find and run the sync script
if [ -n "$CLAUDE_PLUGIN_ROOT" ]; then
    exec "$CLAUDE_PLUGIN_ROOT/hooks-handlers/sync.sh"
else
    # Fallback: find the plugin directory
    SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    exec "$SCRIPT_DIR/hooks-handlers/sync.sh"
fi
