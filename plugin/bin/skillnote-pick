#!/usr/bin/env python3
"""SkillNote collection picker — two-column terminal UI with search and preview."""
import json
import os
import sys
import time
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def _get_host():
    """Resolve SkillNote API host."""
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", ""))
    if host:
        return host
    host_file = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(host_file):
        try:
            with open(host_file) as f:
                val = f.read().strip()
            if val:
                return val
        except Exception:
            pass
    return "localhost"


def fetch_collections():
    host = _get_host()
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        collections = []
        for c in data:
            skills = []
            try:
                skill_data = json.loads(urllib.request.urlopen(
                    f"{api}/v1/skills?collections={c['name']}", timeout=3
                ).read())
                skills = [(s["slug"], s.get("description", "")) for s in skill_data]
            except Exception:
                pass
            collections.append((c["name"], c["count"], skills))
        return host, collections
    except Exception:
        return host, []


def _get_recommended(items):
    names = [n.lower() for n, _, _ in items]
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                cfg = json.load(f)
            current = cfg.get("collections", [])
            if current:
                for i, (n, _, _) in enumerate(items):
                    if n.lower() == current[0].lower():
                        return i
        except Exception:
            pass
    folder = os.path.basename(os.getcwd()).lower()
    for i, name in enumerate(names):
        if name == folder:
            return i
    return 0


def _get_current_collections():
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                return json.load(f).get("collections", [])
        except Exception:
            pass
    return None


def _clean_skills_dir():
    import shutil
    skills_dir = os.path.join(".claude", "skills")
    if os.path.isdir(skills_dir):
        for entry in os.listdir(skills_dir):
            path = os.path.join(skills_dir, entry)
            if os.path.isdir(path):
                shutil.rmtree(path)
            elif entry.endswith(".json"):
                os.remove(path)


def _run_sync():
    host = _get_host()
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        sync_path = os.path.join(plugin_root, "hooks-handlers", "sync.sh")
        if os.path.exists(sync_path):
            os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
            os.system(f'"{sync_path}" 2>/dev/null')
            return
    mkt_sync = os.path.expanduser(
        "~/.claude/plugins/marketplaces/skillnote-local/plugins/skillnote/hooks-handlers/sync.sh"
    )
    if os.path.exists(mkt_sync):
        os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
        os.system(f'"{mkt_sync}" 2>/dev/null')
        return
    os.system("skillnote-sync --force 2>/dev/null")


def pick(stdscr, items, recommended=0):
    cur = recommended
    search = ""
    scroll_offset = 0
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_WHITE, -1)
    curses.init_pair(4, curses.COLOR_YELLOW, -1)
    try:
        curses.init_pair(5, 208, -1)
    except Exception:
        curses.init_pair(5, curses.COLOR_RED, -1)

    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    time.sleep(0.15)

    total_skills = sum(c for _, c, _ in items)
    host = _get_host()
    web_url = f"http://{host}:3000"
    clawd = ["  ▐▛███▜▌", " ▝▜█████▛▘", "   ▘▘ ▝▝"]

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()

        if search:
            filtered = [(i, it) for i, it in enumerate(items) if search.lower() in it[0].lower()]
        else:
            filtered = list(enumerate(items))
        if filtered:
            cur = max(0, min(cur, len(filtered) - 1))

        # ── Responsive layout: use full terminal ──
        pad = 2                              # padding from edges
        bw = w - pad * 2                     # full width minus padding
        bx = pad                             # left edge
        left_w = max(30, bw * 2 // 5)       # left panel ~40%, min 30
        right_w = bw - left_w - 1            # right panel fills rest
        header_rows = 8                      # rows for header (clawd + stats + search)
        footer_rows = 3                      # bottom bar + border
        body_rows = h - header_rows - footer_rows  # rows for collection list

        BORDER = curses.color_pair(1) | curses.A_DIM
        ORANGE = curses.color_pair(5) | curses.A_BOLD
        CYAN_B = curses.color_pair(1) | curses.A_BOLD
        DIM = curses.A_DIM
        BOLD = curses.A_BOLD
        GREEN = curses.color_pair(2)
        YELLOW = curses.color_pair(4)

        def s(r, c, text, attr=0):
            try:
                if 0 <= r < h and 0 <= c < w:
                    stdscr.addstr(r, c, text[:max(0, w - c - 1)], attr)
            except curses.error:
                pass

        def borders(r):
            s(r, bx, "│", BORDER)
            s(r, bx + left_w, "│", BORDER)
            s(r, bx + bw - 1, "│", BORDER)

        row = 0

        try:
            # ── Top border ──
            top = "╭─ ✦ SkillNote " + "─" * max(0, left_w - 16) + "┬" + "─" * right_w + "╮"
            s(row, bx, top[:bw], BORDER)
            s(row, bx + 4, "✦", CYAN_B)
            s(row, bx + 6, "SkillNote", CYAN_B)
            row += 1

            # ── Empty + Clawd + brand ──
            borders(row); row += 1

            for i, cl in enumerate(clawd):
                borders(row)
                s(row, bx + 3, cl, ORANGE)
                if i == 1:
                    me = bx + 3 + len(cl) + 2
                    s(row, me, "×", DIM)
                    s(row, me + 2, "S K I L L N O T E", CYAN_B)
                row += 1

            # ── Stats ──
            borders(row)
            s(row, bx + 3, "●", GREEN)
            s(row, bx + 5, f"{total_skills} skills · {len(items)} collections", DIM)
            row += 1

            # ── Search ──
            borders(row)
            s(row, bx + 3, "> ", BOLD)
            if search:
                s(row, bx + 5, search, BOLD)
            s(row, bx + 5 + len(search), "▌", CYAN_B)
            if search:
                mt = f"{len(filtered)} match{'es' if len(filtered) != 1 else ''}"
                s(row, bx + left_w - len(mt) - 2, mt, DIM)
            row += 1

            # ── Right panel header ──
            sel_name = ""
            sel_skills = []
            if filtered:
                _, (sel_name, _, sel_skills) = filtered[cur]

            rh_row = 2  # right panel starts at row 2
            s(rh_row, bx + left_w + 3, sel_name, BOLD)
            rh_row += 1
            s(rh_row, bx + left_w + 3, "─" * (right_w - 5), DIM)
            rh_row += 1

            # Right panel: skills with descriptions
            for slug, desc in sel_skills:
                if rh_row >= h - footer_rows:
                    break
                s(rh_row, bx + left_w, "│", BORDER)
                s(rh_row, bx + bw - 1, "│", BORDER)
                s(rh_row, bx + left_w + 3, slug, curses.color_pair(1))
                rh_row += 1
                if desc and rh_row < h - footer_rows:
                    short = desc[:right_w - 6]
                    if len(desc) > right_w - 6:
                        sp = short.rfind(" ")
                        if sp > 0:
                            short = short[:sp] + "..."
                    s(rh_row, bx + left_w, "│", BORDER)
                    s(rh_row, bx + bw - 1, "│", BORDER)
                    s(rh_row, bx + left_w + 3, short, DIM)
                    rh_row += 1

            # Fill right panel empty rows
            while rh_row < h - footer_rows:
                s(rh_row, bx + left_w, "│", BORDER)
                s(rh_row, bx + bw - 1, "│", BORDER)
                rh_row += 1

            # ── Collection list (left panel, scrollable) ──
            list_start = row
            visible = body_rows

            # Scroll handling
            if cur < scroll_offset:
                scroll_offset = cur
            elif cur >= scroll_offset + visible:
                scroll_offset = cur - visible + 1

            vis_items = filtered[scroll_offset:scroll_offset + visible]

            for vi, (orig_idx, (name, count, skills)) in enumerate(vis_items):
                if row >= h - footer_rows:
                    break
                fi = scroll_offset + vi
                is_rec = (orig_idx == recommended)
                borders(row)

                if fi == cur:
                    s(row, bx + 3, "❯", CYAN_B)
                    s(row, bx + 5, name, BOLD)
                    if is_rec:
                        s(row, bx + 5 + len(name) + 1, "★", YELLOW)
                    cnt = str(count)
                    s(row, bx + left_w - len(cnt) - 2, cnt, DIM)
                else:
                    s(row, bx + 5, name, DIM)
                    if is_rec:
                        s(row, bx + 5 + len(name) + 1, "★", YELLOW | DIM)
                    cnt = str(count)
                    s(row, bx + left_w - len(cnt) - 2, cnt, DIM)
                row += 1

            # Fill remaining left panel rows
            while row < h - footer_rows:
                borders(row)
                row += 1

            # ── Bottom bar ──
            mid = "├" + "─" * (left_w - 1) + "┴" + "─" * right_w + "┤"
            s(row, bx, mid[:bw], BORDER)
            row += 1

            borders(row)
            s(row, bx + 3, web_url, DIM | curses.color_pair(1))
            gh = "github.com/luna-prompts/skillnote  ★"
            s(row, bx + bw - len(gh) - 2, gh, DIM)
            row += 1

            bot = "╰" + "─" * (left_w - 1) + "─" + "─" * right_w + "╯"
            s(row, bx, bot[:bw], BORDER)
            # Hints on bottom border
            hints = " ↑/↓ navigate · type to search · Enter select · q keep current "
            s(row, bx + 3, hints, DIM)

        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP:
            if cur > 0:
                cur -= 1
        elif key == curses.KEY_DOWN:
            if filtered and cur < len(filtered) - 1:
                cur += 1
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if filtered:
                return [items[filtered[cur][0]][0]]
        elif key in (ord("q"), 27):
            return None
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            search = search[:-1]
            cur = 0
            scroll_offset = 0
        elif 32 <= key <= 126:
            search += chr(key)
            cur = 0
            scroll_offset = 0


def pick_fallback(items, recommended=0):
    print("\n  ✦ SkillNote — Pick a collection\n")
    for i, (name, count, skills) in enumerate(items, 1):
        rec = " ★" if i - 1 == recommended else ""
        print(f"  {i}. {name} ({count} skills){rec}")
        if skills:
            print(f"     {', '.join(s for s, _ in skills[:5])}")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[n - 1][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if not os.isatty(0) or not os.isatty(1):
        return

    host, collections = fetch_collections()

    if not collections:
        print(f"  ✦ SkillNote: could not reach API at http://{host}:8082", file=sys.stderr)
        return

    if len(collections) == 1:
        name, count, _ = collections[0]
        if not os.path.isfile(".skillnote.json"):
            try:
                with open(".skillnote.json", "w") as f:
                    json.dump({"collections": [name]}, f, indent=2)
                    f.write("\n")
                _run_sync()
            except PermissionError:
                pass
        print(f"  ✦ SkillNote: {name} ({count} skills)")
        return

    recommended = _get_recommended(collections)

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections, recommended)
    else:
        chosen = pick_fallback(collections, recommended)

    if not chosen:
        current = _get_current_collections()
        if current:
            print(f"  ✦ SkillNote: {', '.join(current)} (active)")
        return

    current = _get_current_collections()
    changed = current != chosen

    try:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
    except PermissionError:
        print("  ✦ SkillNote: cannot write .skillnote.json (permission denied)", file=sys.stderr)
        return

    if changed and current is not None:
        _clean_skills_dir()

    names = ", ".join(chosen)
    total = sum(c for n, c, _ in collections if n in chosen)
    print(f"\n  ✦ SkillNote: {names} ({total} skills)\n")

    _run_sync()


if __name__ == "__main__":
    main()
