#!/usr/bin/env python3
"""SkillNote collection picker — native terminal UI."""
import json
import os
import sys
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def fetch_collections():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        return [(c["name"], c["count"]) for c in data]
    except Exception:
        return []


def pick(stdscr, items):
    selected = set()
    cur = 0
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # accent/teal
    curses.init_pair(2, curses.COLOR_GREEN, -1)     # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)     # bright
    curses.init_pair(4, curses.COLOR_YELLOW, -1)    # highlight

    # Flush stale input (the Enter from typing 'claude')
    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    import time
    time.sleep(0.1)

    total_skills = sum(c for _, c in items)

    while True:
        stdscr.clear()
        h, w = stdscr.getmaxyx()
        row = 0

        # ── Get info ──
        host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
        web_url = f"http://{host}:3000"
        n_sel = len(selected)
        sel_skills = sum(items[i][1] for i in selected)
        sel_names = ", ".join(items[i][0] for i in sorted(selected))

        # ── Layout ──
        bw = min(w - 4, 80)  # box width
        bx = (w - bw) // 2   # center horizontally
        iw = bw - 4          # inner width

        def ctr(text, width=iw):
            pad = max(0, width - len(text))
            return " " * (pad // 2) + text + " " * (pad - pad // 2)

        def box_line(left, fill, right, attr=curses.color_pair(1)):
            try:
                stdscr.addstr(row, bx, left + fill * iw + right, attr)
            except curses.error:
                pass

        try:
            # ── Top border ──
            box_line("╭─", "─", "─╮")
            row += 1

            # ── Brand ──
            stdscr.addstr(row, bx, "│ ", curses.color_pair(1))
            stdscr.addstr(ctr(""), curses.color_pair(1))
            stdscr.addstr("│", curses.color_pair(1))
            row += 1

            # ── Brand: clean centered layout ──
            def box_empty():
                nonlocal row
                stdscr.addstr(row, bx, "│", curses.color_pair(1))
                stdscr.addstr(" " * (bw - 2))
                stdscr.addstr("│", curses.color_pair(1))
                row += 1

            def box_center(text, attr=0):
                nonlocal row
                stdscr.addstr(row, bx, "│", curses.color_pair(1))
                ct = ctr(text, bw - 2)
                idx = ct.find(text)
                stdscr.addstr(ct[:idx])
                stdscr.addstr(text, attr)
                stdscr.addstr(ct[idx+len(text):])
                stdscr.addstr("│", curses.color_pair(1))
                row += 1

            box_empty()
            box_center("S K I L L N O T E", curses.A_BOLD | curses.color_pair(1))
            box_empty()
            box_center(f"{total_skills} skills  ·  {len(items)} collections", curses.A_DIM)
            box_center(web_url, curses.A_DIM)
            box_empty()

            # ── Separator ──
            stdscr.addstr(row, bx, "├─", curses.color_pair(1))
            stdscr.addstr("─" * iw, curses.color_pair(1))
            stdscr.addstr("─┤", curses.color_pair(1))
            row += 1

            # ── Section header ──
            stdscr.addstr(row, bx, "│ ", curses.color_pair(1))
            sh = "  Select collections for this project"
            stdscr.addstr(sh[:iw], curses.A_DIM)
            stdscr.addstr(" " * max(0, iw - len(sh)), curses.A_DIM)
            stdscr.addstr("│", curses.color_pair(1))
            row += 1

            stdscr.addstr(row, bx, "│ ", curses.color_pair(1))
            stdscr.addstr(" " * iw)
            stdscr.addstr("│", curses.color_pair(1))
            row += 1

            # ── Collection items ──
            for i, (name, count) in enumerate(items):
                if row >= h - 4:
                    break
                mark = "◉" if i in selected else "○"
                pointer = "❯" if i == cur else " "

                stdscr.addstr(row, bx, "│ ", curses.color_pair(1))

                item_str = f"  {pointer} {mark} {name}  ({count} skills)"
                pad_r = max(0, iw - len(item_str))

                stdscr.addstr(f"  {pointer} ", curses.A_BOLD if i == cur else curses.A_DIM)
                if i in selected:
                    stdscr.addstr(f"{mark} ", curses.color_pair(2) | curses.A_BOLD)
                    stdscr.addstr(name, curses.color_pair(2) | curses.A_BOLD)
                elif i == cur:
                    stdscr.addstr(f"{mark} ", curses.color_pair(4))
                    stdscr.addstr(name, curses.A_BOLD)
                else:
                    stdscr.addstr(f"{mark} ", curses.A_DIM)
                    stdscr.addstr(name)
                stdscr.addstr(f"  ({count} skills)", curses.A_DIM)
                # Fill rest of line
                cx = stdscr.getyx()[1]
                remaining = bx + bw - 1 - cx
                if remaining > 0:
                    stdscr.addstr(" " * remaining)
                stdscr.addstr("│", curses.color_pair(1))
                row += 1

            # ── Empty line ──
            stdscr.addstr(row, bx, "│ ", curses.color_pair(1))
            stdscr.addstr(" " * iw)
            stdscr.addstr("│", curses.color_pair(1))
            row += 1

            # ── Status ──
            stdscr.addstr(row, bx, "│ ", curses.color_pair(1))
            if n_sel > 0:
                status = f"  {n_sel} selected: {sel_names} ({sel_skills} skills)"
            else:
                status = "  Enter = all collections"
            stdscr.addstr(status[:iw], curses.color_pair(2) if n_sel > 0 else curses.A_DIM)
            sx = stdscr.getyx()[1]
            rem = bx + bw - 1 - sx
            if rem > 0:
                stdscr.addstr(" " * rem)
            stdscr.addstr("│", curses.color_pair(1))
            row += 1

            # ── Bottom border ──
            box_line("╰─", "─", "─╯")
            row += 1

        except curses.error:
            pass

        # ── Hints (outside box) ──
        try:
            hints = " ↑↓ move · Space select · Enter confirm · q skip"
            stdscr.addstr(min(row, h - 1), bx + 2, hints[:bw-4], curses.A_DIM)
        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP and cur > 0:
            cur -= 1
        elif key == curses.KEY_DOWN and cur < len(items) - 1:
            cur += 1
        elif key == ord(" "):
            selected ^= {cur}
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if selected:
                return [items[i][0] for i in sorted(selected)]
            else:
                return []
        elif key in (ord("q"), 27):
            return None


def pick_fallback(items):
    print("\n SkillNote — Pick collections for this project")
    print(" Enter numbers separated by commas, or 'q' to skip:\n")
    for i, (name, count) in enumerate(items, 1):
        print(f"  {i}. {name} ({count} skills)")
    print(f"  {len(items) + 1}. All collections (no filter)")
    print()
    try:
        reply = input(" > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        nums = [int(x.strip()) for x in reply.split(",")]
        if len(items) + 1 in nums:
            return []
        return [items[n - 1][0] for n in nums if 1 <= n <= len(items)]
    except (ValueError, IndexError):
        return None


def main():
    if os.path.exists(".skillnote.json"):
        return
    if not os.isatty(0) or not os.isatty(1):
        return

    collections = fetch_collections()
    if len(collections) <= 1:
        return

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections)
    else:
        chosen = pick_fallback(collections)

    if chosen is None:
        return

    if chosen:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
        names = ", ".join(chosen)
        total = sum(c for n, c in collections if n in chosen)
        print(f"SkillNote: {names} ({total} skills)")

        plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
        if plugin_root:
            os.system(f'"{plugin_root}/hooks-handlers/sync.sh" 2>/dev/null')
        else:
            os.system("skillnote-sync --force 2>/dev/null")
    else:
        print("SkillNote: all collections")


if __name__ == "__main__":
    main()
