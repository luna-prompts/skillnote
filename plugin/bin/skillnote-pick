#!/usr/bin/env python3
"""SkillNote collection picker — two-column terminal UI with search and preview."""
import json
import os
import sys
import time
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def _get_host():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", ""))
    if host:
        return host
    host_file = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(host_file):
        try:
            with open(host_file) as f:
                val = f.read().strip()
            if val:
                return val
        except Exception:
            pass
    return "localhost"


def fetch_collections():
    host = _get_host()
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        collections = []
        for c in data:
            skills = []
            try:
                skill_data = json.loads(urllib.request.urlopen(
                    f"{api}/v1/skills?collections={c['name']}", timeout=3
                ).read())
                skills = [(s["slug"], s.get("description", "")) for s in skill_data]
            except Exception:
                pass
            collections.append((c["name"], c["count"], skills))
        return host, collections
    except Exception:
        return host, []


def _get_recommended(items):
    names = [n.lower() for n, _, _ in items]
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                cfg = json.load(f)
            current = cfg.get("collections", [])
            if current:
                for i, (n, _, _) in enumerate(items):
                    if n.lower() == current[0].lower():
                        return i
        except Exception:
            pass
    folder = os.path.basename(os.getcwd()).lower()
    for i, name in enumerate(names):
        if name == folder:
            return i
    return 0


def _get_current_collections():
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                return json.load(f).get("collections", [])
        except Exception:
            pass
    return None


def _clean_skills_dir():
    import shutil
    skills_dir = os.path.join(".claude", "skills")
    if os.path.isdir(skills_dir):
        for entry in os.listdir(skills_dir):
            path = os.path.join(skills_dir, entry)
            if os.path.isdir(path):
                shutil.rmtree(path)
            elif entry.endswith(".json"):
                os.remove(path)


def _run_sync():
    host = _get_host()
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        sync_path = os.path.join(plugin_root, "hooks-handlers", "sync.sh")
        if os.path.exists(sync_path):
            os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
            os.system(f'"{sync_path}" 2>/dev/null')
            return
    mkt_sync = os.path.expanduser(
        "~/.claude/plugins/marketplaces/skillnote-local/plugins/skillnote/hooks-handlers/sync.sh"
    )
    if os.path.exists(mkt_sync):
        os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
        os.system(f'"{mkt_sync}" 2>/dev/null')
        return
    os.system("skillnote-sync --force 2>/dev/null")


def pick(stdscr, items, recommended=0):
    # Sort: recommended first, then rest in original order
    sorted_items = []
    if 0 <= recommended < len(items):
        sorted_items.append((recommended, items[recommended]))
    for i, it in enumerate(items):
        if i != recommended:
            sorted_items.append((i, it))

    cur = 0  # recommended is now always index 0
    search = ""
    scroll_offset = 0

    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_WHITE, -1)
    curses.init_pair(4, curses.COLOR_YELLOW, -1)
    try:
        curses.init_pair(5, 208, -1)  # orange for Clawd
    except Exception:
        curses.init_pair(5, curses.COLOR_RED, -1)

    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    time.sleep(0.15)

    total_skills = sum(c for _, c, _ in items)
    host = _get_host()
    web_url = f"http://{host}:3000"
    gh_url = "github.com/luna-prompts/skillnote"
    clawd = ["  ▐▛███▜▌", " ▝▜█████▛▘", "   ▘▘ ▝▝"]

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()

        # Filter
        if search:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)
                        if search.lower() in it[0].lower()]
        else:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)]

        if filtered:
            cur = max(0, min(cur, len(filtered) - 1))

        # Layout — full screen with padding
        pad = 2
        bw = w - pad * 2
        bx = pad
        left_w = max(28, min(bw * 2 // 5, 44))
        right_w = bw - left_w - 1
        header_h = 6   # top border + empty + 3 clawd + empty
        footer_h = 1   # bottom border with hints
        sep_h = 1      # separator with stats
        body_h = h - header_h - sep_h - footer_h

        BORDER = curses.color_pair(1) | curses.A_DIM
        ORANGE = curses.color_pair(5) | curses.A_BOLD
        CYAN = curses.color_pair(1) | curses.A_BOLD
        DIM = curses.A_DIM
        BOLD = curses.A_BOLD
        GREEN = curses.color_pair(2)
        YELLOW = curses.color_pair(4)

        def s(r, c, text, attr=0):
            try:
                if 0 <= r < h and 0 <= c < w:
                    stdscr.addstr(r, c, text[:max(0, w - c - 1)], attr)
            except curses.error:
                pass

        row = 0

        try:
            # ═══ HEADER: brand zone (full width, no column split) ═══

            # Top border
            s(row, bx, "╭" + "─" * (bw - 2) + "╮", BORDER)
            row += 1

            # Empty breathing line
            s(row, bx, "│", BORDER)
            s(row, bx + bw - 1, "│", BORDER)
            row += 1

            # Clawd line 1
            s(row, bx, "│", BORDER)
            s(row, bx + 4, clawd[0], ORANGE)
            s(row, bx + bw - 1, "│", BORDER)
            row += 1

            # Clawd line 2 + brand
            s(row, bx, "│", BORDER)
            s(row, bx + 3, clawd[1], ORANGE)
            brand_x = bx + 3 + len(clawd[1]) + 2
            s(row, brand_x, "×", DIM)
            s(row, brand_x + 2, "S K I L L N O T E", CYAN)
            s(row, bx + bw - 1, "│", BORDER)
            row += 1

            # Clawd line 3
            s(row, bx, "│", BORDER)
            s(row, bx + 4, clawd[2], ORANGE)
            s(row, bx + bw - 1, "│", BORDER)
            row += 1

            # Empty breathing line
            s(row, bx, "│", BORDER)
            s(row, bx + bw - 1, "│", BORDER)
            row += 1

            # ═══ SEPARATOR: stats + column split ═══
            sep_text = f" ● {total_skills} skills · {len(items)} collections "
            sep_left = "├──" + sep_text + "─" * max(0, left_w - len(sep_text) - 3)
            sep_right = "┬" + "─" * (right_w) + "┤"
            s(row, bx, (sep_left + sep_right)[:bw], BORDER)
            # Color the stats
            s(row, bx + 4, "●", GREEN)
            s(row, bx + 6, f"{total_skills} skills · {len(items)} collections", DIM)
            row += 1

            # ═══ CONTENT: two columns ═══
            content_start = row

            # Get selected collection for right panel
            sel_name = ""
            sel_count = 0
            sel_skills = []
            sel_is_rec = False
            if filtered:
                _, orig_idx, (sel_name, sel_count, sel_skills) = filtered[cur]
                sel_is_rec = (orig_idx == recommended)

            # --- RIGHT PANEL (render first so we know how many rows it needs) ---
            rr = content_start

            # Empty line
            s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
            rr += 1

            # Collection name header
            s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
            header_text = sel_name
            if sel_is_rec:
                header_text += " ★"
            s(rr, bx + left_w + 4, header_text, BOLD)
            count_text = f"{sel_count} skills"
            s(rr, bx + bw - len(count_text) - 3, count_text, DIM)
            rr += 1

            # Separator
            s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
            s(rr, bx + left_w + 4, "─" * (right_w - 6), DIM)
            rr += 1

            # Empty line
            s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
            rr += 1

            # Skill list with numbers
            for si, (slug, desc) in enumerate(sel_skills):
                if rr >= h - footer_h - 1:
                    break

                # Number + skill name
                s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
                num = f"{si + 1}."
                s(rr, bx + left_w + 4, num, DIM)
                s(rr, bx + left_w + 4 + len(num) + 1, slug, curses.color_pair(1))
                rr += 1

                # Description
                if desc and rr < h - footer_h - 1:
                    s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
                    short = desc[:right_w - 9]
                    if len(desc) > right_w - 9:
                        sp = short.rfind(" ")
                        if sp > 0:
                            short = short[:sp] + "..."
                    s(rr, bx + left_w + 8, short, DIM)
                    rr += 1

                # Empty line between skills
                if rr < h - footer_h - 1:
                    s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
                    rr += 1

            # Fill remaining right panel rows
            while rr < h - footer_h:
                s(rr, bx + left_w, "│", BORDER); s(rr, bx + bw - 1, "│", BORDER)
                rr += 1

            # --- LEFT PANEL ---
            lr = content_start

            # Empty line
            s(lr, bx, "│", BORDER)
            lr += 1

            # Search input
            s(lr, bx, "│", BORDER)
            s(lr, bx + 4, ">", BOLD)
            if search:
                s(lr, bx + 6, search, BOLD)
            s(lr, bx + 6 + len(search), "▌", CYAN)
            if search:
                mt = f"{len(filtered)} match{'es' if len(filtered) != 1 else ''}"
                s(lr, bx + left_w - len(mt) - 2, mt, DIM)
            lr += 1

            # Empty line
            s(lr, bx, "│", BORDER)
            lr += 1

            # Collection list with numbers
            list_area = h - footer_h - lr
            if filtered:
                if cur < scroll_offset:
                    scroll_offset = cur
                elif cur >= scroll_offset + list_area:
                    scroll_offset = cur - list_area + 1

            vis = filtered[scroll_offset:scroll_offset + list_area]

            for vi, (sorted_idx, orig_idx, (name, count, skills)) in enumerate(vis):
                if lr >= h - footer_h:
                    break
                fi = scroll_offset + vi
                is_rec = (orig_idx == recommended)

                s(lr, bx, "│", BORDER)

                num = f"{fi + 1}."
                if fi == cur:
                    s(lr, bx + 4, num, CYAN)
                    s(lr, bx + 4 + len(num), " ❯", CYAN)
                    s(lr, bx + 4 + len(num) + 3, name, BOLD)
                    if is_rec:
                        s(lr, bx + 4 + len(num) + 3 + len(name) + 1, "★", YELLOW)
                    cnt = str(count)
                    s(lr, bx + left_w - len(cnt) - 2, cnt, DIM)
                else:
                    s(lr, bx + 4, num, DIM)
                    s(lr, bx + 4 + len(num) + 3, name, DIM)
                    if is_rec:
                        s(lr, bx + 4 + len(num) + 3 + len(name) + 1, "★", YELLOW | DIM)
                    cnt = str(count)
                    s(lr, bx + left_w - len(cnt) - 2, cnt, DIM)
                lr += 1

            # Fill remaining left panel rows
            while lr < h - footer_h:
                s(lr, bx, "│", BORDER)
                lr += 1

            # ═══ FOOTER: hints left, links right ═══
            hints = " ↑/↓ navigate · type to search · Enter select · q keep current "
            links = f" {web_url} · {gh_url} ★ "
            bot = "╰──" + hints + "─" * max(0, bw - len(hints) - len(links) - 4) + links + "─╯"
            s(h - 1, bx, bot[:bw], BORDER)
            # Re-color the hints
            s(h - 1, bx + 3, hints.strip(), DIM)
            # Re-color the links
            link_start = bx + bw - len(links) - 1
            s(h - 1, link_start, links.strip(), DIM | curses.color_pair(1))

        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP:
            if cur > 0:
                cur -= 1
        elif key == curses.KEY_DOWN:
            if filtered and cur < len(filtered) - 1:
                cur += 1
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if filtered:
                _, orig_idx, _ = filtered[cur]
                return [items[orig_idx][0]]
        elif key in (ord("q"), 27):
            return None
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            search = search[:-1]
            cur = 0
            scroll_offset = 0
        elif 32 <= key <= 126:
            search += chr(key)
            cur = 0
            scroll_offset = 0


def pick_fallback(items, recommended=0):
    print("\n  ✦ SkillNote — Pick a collection\n")
    # Show recommended first
    order = [recommended] + [i for i in range(len(items)) if i != recommended]
    for pos, i in enumerate(order):
        name, count, skills = items[i]
        rec = " ★" if i == recommended else ""
        print(f"  {pos + 1}. {name} ({count} skills){rec}")
        if skills:
            print(f"     {', '.join(s for s, _ in skills[:5])}")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[order[n - 1]][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if not os.isatty(0) or not os.isatty(1):
        return

    host, collections = fetch_collections()

    if not collections:
        print(f"  ✦ SkillNote: could not reach API at http://{host}:8082", file=sys.stderr)
        return

    if len(collections) == 1:
        name, count, _ = collections[0]
        if not os.path.isfile(".skillnote.json"):
            try:
                with open(".skillnote.json", "w") as f:
                    json.dump({"collections": [name]}, f, indent=2)
                    f.write("\n")
                _run_sync()
            except PermissionError:
                pass
        print(f"  ✦ SkillNote: {name} ({count} skills)")
        return

    recommended = _get_recommended(collections)

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections, recommended)
    else:
        chosen = pick_fallback(collections, recommended)

    if not chosen:
        current = _get_current_collections()
        if current:
            print(f"  ✦ SkillNote: {', '.join(current)} (active)")
        return

    current = _get_current_collections()
    changed = current != chosen

    try:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
    except PermissionError:
        print("  ✦ SkillNote: cannot write .skillnote.json (permission denied)", file=sys.stderr)
        return

    if changed and current is not None:
        _clean_skills_dir()

    names = ", ".join(chosen)
    total = sum(c for n, c, _ in collections if n in chosen)
    print(f"\n  ✦ SkillNote: {names} ({total} skills)\n")

    _run_sync()


if __name__ == "__main__":
    main()
