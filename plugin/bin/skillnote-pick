#!/usr/bin/env python3
"""SkillNote collection picker Рђћ native terminal UI."""
import json
import os
import sys
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def fetch_collections():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        return [(c["name"], c["count"]) for c in data]
    except Exception:
        return []


def pick(stdscr, items):
    selected = set()
    cur = 0
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # accent/teal
    curses.init_pair(2, curses.COLOR_GREEN, -1)     # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)     # bright
    curses.init_pair(4, curses.COLOR_YELLOW, -1)    # highlight

    # Flush stale input (the Enter from typing 'claude')
    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    import time
    time.sleep(0.1)

    total_skills = sum(c for _, c in items)

    while True:
        stdscr.clear()
        h, w = stdscr.getmaxyx()
        row = 0

        # РћђРћђ Get info РћђРћђ
        host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
        web_url = f"http://{host}:3000"
        n_sel = len(selected)
        sel_skills = sum(items[i][1] for i in selected)
        sel_names = ", ".join(items[i][0] for i in sorted(selected))

        # РћђРћђ Layout РћђРћђ
        bw = min(w - 4, 80)  # box width
        bx = (w - bw) // 2   # center horizontally
        iw = bw - 4          # inner width

        def ctr(text, width=iw):
            pad = max(0, width - len(text))
            return " " * (pad // 2) + text + " " * (pad - pad // 2)

        def box_line(left, fill, right, attr=curses.color_pair(1)):
            try:
                stdscr.addstr(row, bx, left + fill * iw + right, attr)
            except curses.error:
                pass

        try:
            # РћђРћђ Top border РћђРћђ
            box_line("РЋГРћђ", "Рћђ", "РћђРЋ«")
            row += 1

            # РћђРћђ Brand РћђРћђ
            stdscr.addstr(row, bx, "Рћѓ ", curses.color_pair(1))
            stdscr.addstr(ctr(""), curses.color_pair(1))
            stdscr.addstr("Рћѓ", curses.color_pair(1))
            row += 1

            # РћђРћђ Helpers РћђРћђ
            def box_empty():
                nonlocal row
                try:
                    stdscr.addstr(row, bx, "Рћѓ", curses.color_pair(1))
                    stdscr.addstr(" " * (bw - 2))
                    stdscr.addstr("Рћѓ", curses.color_pair(1))
                except curses.error: pass
                row += 1

            def box_center(text, attr=0):
                nonlocal row
                try:
                    stdscr.addstr(row, bx, "Рћѓ", curses.color_pair(1))
                    ct = ctr(text, bw - 2)
                    idx = ct.find(text) if text in ct else 0
                    stdscr.addstr(ct[:idx])
                    stdscr.addstr(text, attr)
                    remaining = bw - 2 - idx - len(text)
                    if remaining > 0:
                        stdscr.addstr(" " * remaining)
                    stdscr.addstr("Рћѓ", curses.color_pair(1))
                except curses.error: pass
                row += 1

            def box_left(text, attr=0):
                nonlocal row
                try:
                    stdscr.addstr(row, bx, "Рћѓ", curses.color_pair(1))
                    stdscr.addstr(f"  {text}", attr)
                    cx = stdscr.getyx()[1]
                    rem = bx + bw - 1 - cx
                    if rem > 0: stdscr.addstr(" " * rem)
                    stdscr.addstr("Рћѓ", curses.color_pair(1))
                except curses.error: pass
                row += 1

            def box_kv(key, key_attr, val, val_attr):
                nonlocal row
                try:
                    stdscr.addstr(row, bx, "Рћѓ", curses.color_pair(1))
                    stdscr.addstr(f"  {key}", key_attr)
                    stdscr.addstr(f"  {val}", val_attr)
                    cx = stdscr.getyx()[1]
                    rem = bx + bw - 1 - cx
                    if rem > 0: stdscr.addstr(" " * rem)
                    stdscr.addstr("Рћѓ", curses.color_pair(1))
                except curses.error: pass
                row += 1

            # РћђРћђ ASCII Art Brand РћђРћђ
            brand = [
                "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЌ  РќѕРќѕРЋЌРќѕРќѕРЋЌРќѕРќѕРЋЌ     РќѕРќѕРЋЌ     РќѕРќѕРќѕРЋЌ   РќѕРќѕРЋЌ РќѕРќѕРќѕРќѕРќѕРќѕРЋЌ РќѕРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ",
                "РќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРЋЉ РќѕРќѕРЋћРЋЮРќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋљРќѕРќѕРЋЌРЋџРЋљРЋљРќѕРќѕРЋћРЋљРЋљРЋЮРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮ",
                "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРЋћРЋЮ РќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРЋћРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРќѕРќѕРќѕРЋЌ  ",
                "РЋџРЋљРЋљРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋћРЋљРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРЋЉРЋџРќѕРќѕРЋЌРќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋћРЋљРЋљРЋЮ  ",
                "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРЋЉ  РќѕРќѕРЋЌРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЉ РЋџРќѕРќѕРќѕРќѕРЋЉРЋџРќѕРќѕРќѕРќѕРќѕРќѕРЋћРЋЮ   РќѕРќѕРЋЉ   РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ",
                "РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋЮРЋџРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋљРЋљРЋЮ РЋџРЋљРЋљРЋљРЋљРЋљРЋЮ    РЋџРЋљРЋЮ   РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ",
            ]
            box_empty()
            for bl in brand:
                if bw - 2 >= len(bl):
                    box_center(bl, curses.A_BOLD | curses.color_pair(1))
                else:
                    # Terminal too narrow for the big art Рђћ use simple text
                    box_center("S K I L L N O T E", curses.A_BOLD | curses.color_pair(1))
                    break
            box_empty()

            # РћђРћђ Info lines РћђРћђ
            box_center("Reusable skills for AI coding agents", curses.A_DIM)
            box_center(f"{total_skills} skills  ┬и  {len(items)} collections  ┬и  {web_url}", curses.A_DIM)
            box_empty()

            # РћђРћђ Separator РћђРћђ
            stdscr.addstr(row, bx, "РћюРћђ", curses.color_pair(1))
            stdscr.addstr("Рћђ" * iw, curses.color_pair(1))
            stdscr.addstr("РћђРћц", curses.color_pair(1))
            row += 1

            # РћђРћђ Section header РћђРћђ
            stdscr.addstr(row, bx, "Рћѓ ", curses.color_pair(1))
            sh = "  Pick collections for this project (Space to toggle)"
            stdscr.addstr(sh[:iw], curses.A_DIM)
            stdscr.addstr(" " * max(0, iw - len(sh)), curses.A_DIM)
            stdscr.addstr("Рћѓ", curses.color_pair(1))
            row += 1

            stdscr.addstr(row, bx, "Рћѓ ", curses.color_pair(1))
            stdscr.addstr(" " * iw)
            stdscr.addstr("Рћѓ", curses.color_pair(1))
            row += 1

            # РћђРћђ Collection items РћђРћђ
            for i, (name, count) in enumerate(items):
                if row >= h - 4:
                    break
                mark = "РЌЅ" if i in selected else "РЌІ"
                pointer = "РЮ»" if i == cur else " "

                stdscr.addstr(row, bx, "Рћѓ ", curses.color_pair(1))

                item_str = f"  {pointer} {mark} {name}  ({count} skills)"
                pad_r = max(0, iw - len(item_str))

                stdscr.addstr(f"  {pointer} ", curses.A_BOLD if i == cur else curses.A_DIM)
                if i in selected:
                    stdscr.addstr(f"{mark} ", curses.color_pair(2) | curses.A_BOLD)
                    stdscr.addstr(name, curses.color_pair(2) | curses.A_BOLD)
                elif i == cur:
                    stdscr.addstr(f"{mark} ", curses.color_pair(4))
                    stdscr.addstr(name, curses.A_BOLD)
                else:
                    stdscr.addstr(f"{mark} ", curses.A_DIM)
                    stdscr.addstr(name)
                stdscr.addstr(f"  ({count} skills)", curses.A_DIM)
                # Fill rest of line
                cx = stdscr.getyx()[1]
                remaining = bx + bw - 1 - cx
                if remaining > 0:
                    stdscr.addstr(" " * remaining)
                stdscr.addstr("Рћѓ", curses.color_pair(1))
                row += 1

            # РћђРћђ Empty line РћђРћђ
            box_empty()

            # РћђРћђ Status РћђРћђ
            stdscr.addstr(row, bx, "Рћѓ ", curses.color_pair(1))
            if n_sel > 0:
                status = f"  {n_sel} selected: {sel_names} ({sel_skills} skills)"
            else:
                status = "  Select at least one collection"
            stdscr.addstr(status[:iw], curses.color_pair(2) if n_sel > 0 else curses.A_DIM)
            sx = stdscr.getyx()[1]
            rem = bx + bw - 1 - sx
            if rem > 0:
                stdscr.addstr(" " * rem)
            stdscr.addstr("Рћѓ", curses.color_pair(1))
            row += 1

            # РћђРћђ Actions (if terminal has space) РћђРћђ
            if row < h - 10:
                stdscr.addstr(row, bx, "РћюРћђ", curses.color_pair(1))
                stdscr.addstr("Рћђ" * iw, curses.color_pair(1))
                stdscr.addstr("РћђРћц", curses.color_pair(1))
                row += 1

                box_empty()
                box_kv("Browse all skills Рєњ", curses.A_BOLD,
                       f"{web_url}/collections", curses.color_pair(1) | curses.A_BOLD)
                box_empty()
                box_kv("/skillnote:skill-push", curses.color_pair(4),
                       "Create & push skills from Claude Code", curses.A_DIM)
                box_kv("/skillnote:collection", curses.color_pair(4),
                       "Change active collections anytime", curses.A_DIM)
                box_empty()
                box_center("github.com/luna-prompts/skillnote", curses.A_DIM)
                box_empty()

            # РћђРћђ Bottom border РћђРћђ
            box_line("РЋ░Рћђ", "Рћђ", "РћђРЋ»")
            row += 1

        except curses.error:
            pass

        # РћђРћђ Hints (outside box) РћђРћђ
        try:
            hints = " РєЉ/РєЊ navigate ┬и Space toggle ┬и Enter confirm ┬и q skip"
            stdscr.addstr(min(row, h - 1), bx + 2, hints[:bw-4], curses.A_DIM)
        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP and cur > 0:
            cur -= 1
        elif key == curses.KEY_DOWN and cur < len(items) - 1:
            cur += 1
        elif key == ord(" "):
            selected ^= {cur}
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if selected:
                return [items[i][0] for i in sorted(selected)]
        elif key in (ord("q"), 27):
            return None


def pick_fallback(items):
    print("\n SkillNote Рђћ Pick collections for this project")
    print(" Enter numbers separated by commas, or 'q' to skip:\n")
    for i, (name, count) in enumerate(items, 1):
        print(f"  {i}. {name} ({count} skills)")
    print()
    try:
        reply = input(" > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        nums = [int(x.strip()) for x in reply.split(",")]
        result = [items[n - 1][0] for n in nums if 1 <= n <= len(items)]
        return result if result else None
    except (ValueError, IndexError):
        return None


def main():
    if os.path.exists(".skillnote.json"):
        return
    if not os.isatty(0) or not os.isatty(1):
        return

    collections = fetch_collections()
    if len(collections) <= 1:
        return

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections)
    else:
        chosen = pick_fallback(collections)

    if chosen is None:
        return

    if not chosen:
        return

    with open(".skillnote.json", "w") as f:
        json.dump({"collections": chosen}, f, indent=2)
        f.write("\n")
    names = ", ".join(chosen)
    total = sum(c for n, c in collections if n in chosen)
    print(f"SkillNote: {names} ({total} skills)")

    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        os.system(f'"{plugin_root}/hooks-handlers/sync.sh" 2>/dev/null')
    else:
        os.system("skillnote-sync --force 2>/dev/null")


if __name__ == "__main__":
    main()
