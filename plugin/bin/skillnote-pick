#!/usr/bin/env python3
"""SkillNote collection picker — full-screen two-column box with search and preview."""
import json
import os
import sys
import time
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False

# Constants (from Claude Code's FuzzyPicker study)
MIN_VISIBLE = 2
DEFAULT_VISIBLE = 12
COMPACT_THRESHOLD = 70
LEFT_MIN_W = 28
LEFT_MAX_W = 44


def _get_host():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", ""))
    if host:
        return host
    hf = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(hf):
        try:
            with open(hf) as f:
                v = f.read().strip()
            if v:
                return v
        except Exception:
            pass
    return "localhost"


def fetch_collections():
    host = _get_host()
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        cols = []
        for c in data:
            skills = []
            try:
                sd = json.loads(urllib.request.urlopen(
                    f"{api}/v1/skills?collections={c['name']}", timeout=3).read())
                skills = [(s["slug"], s.get("description", "")) for s in sd]
            except Exception:
                pass
            cols.append((c["name"], c["count"], skills))
        return host, cols
    except Exception:
        return host, []


def _get_recommended(items):
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                cur = json.load(f).get("collections", [])
            if cur:
                for i, (n, _, _) in enumerate(items):
                    if n.lower() == cur[0].lower():
                        return i
        except Exception:
            pass
    folder = os.path.basename(os.getcwd()).lower()
    for i, (n, _, _) in enumerate(items):
        if n.lower() == folder:
            return i
    return 0


def _get_current_collections():
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                return json.load(f).get("collections", [])
        except Exception:
            pass
    return None


def _clean_skills_dir():
    import shutil
    sd = os.path.join(".claude", "skills")
    if os.path.isdir(sd):
        for e in os.listdir(sd):
            p = os.path.join(sd, e)
            if os.path.isdir(p):
                shutil.rmtree(p)
            elif e.endswith(".json"):
                os.remove(p)


def _run_sync():
    host = _get_host()
    pr = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if pr:
        sp = os.path.join(pr, "hooks-handlers", "sync.sh")
        if os.path.exists(sp):
            os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
            os.system(f'"{sp}" 2>/dev/null')
            return
    ms = os.path.expanduser(
        "~/.claude/plugins/marketplaces/skillnote-local/plugins/skillnote/hooks-handlers/sync.sh")
    if os.path.exists(ms):
        os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
        os.system(f'"{ms}" 2>/dev/null')
        return
    os.system("skillnote-sync --force 2>/dev/null")


def _clamp(v, lo, hi):
    return max(lo, min(v, hi))


def _wrap(text, w):
    lines = []
    while text and len(lines) < 4:
        if len(text) <= w:
            lines.append(text)
            break
        sp = text[:w].rfind(" ")
        if sp <= 0:
            sp = w
        lines.append(text[:sp])
        text = text[sp:].lstrip()
    return lines


def _strip_trigger(desc):
    """Remove 'Trigger when: ...' suffix from description."""
    idx = desc.find("Trigger when:")
    if idx > 0:
        return desc[:idx].rstrip(". ")
    return desc


def pick(stdscr, items, recommended=0):
    # Sort: recommended first
    sorted_items = []
    if 0 <= recommended < len(items):
        sorted_items.append((recommended, items[recommended]))
    for i, it in enumerate(items):
        if i != recommended:
            sorted_items.append((i, it))

    cur = 0
    search = ""
    right_scroll = 0
    focus = "left"

    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_YELLOW, -1)
    curses.init_pair(4, curses.COLOR_RED, -1)
    try:
        curses.init_pair(5, 208, -1)
    except Exception:
        curses.init_pair(5, curses.COLOR_RED, -1)

    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    time.sleep(0.15)

    total_skills = sum(c for _, c, _ in items)
    host = _get_host()
    web_url = f"http://{host}:3000"
    gh_url = "github.com/luna-prompts/skillnote"

    BORDER = curses.color_pair(1) | curses.A_DIM
    ACCENT = curses.color_pair(1) | curses.A_BOLD
    GREEN = curses.color_pair(2)
    YELLOW = curses.color_pair(3)
    ORANGE = curses.color_pair(5) | curses.A_BOLD
    DIM = curses.A_DIM
    BOLD = curses.A_BOLD

    clawd = ["▐▛███▜▌", "▝▜█████▛▘", "▘▘ ▝▝"]
    clawd_w = 9

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()

        # Filter
        if search:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)
                        if search.lower() in it[0].lower()]
        else:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)]
        if filtered:
            cur = _clamp(cur, 0, len(filtered) - 1)

        # Layout
        pad = 2
        bw = w - pad * 2
        bx = pad
        left_w = _clamp(bw * 2 // 5, LEFT_MIN_W, LEFT_MAX_W)
        right_w = bw - left_w - 1
        compact = w < COMPACT_THRESHOLD

        header_h = 9   # top + 2empty + clawd(3) + 2empty + separator
        footer_h = 1
        body_h = max(MIN_VISIBLE, h - header_h - footer_h - 1)

        # Selected collection for preview
        sel_name, sel_count, sel_skills = "", 0, []
        sel_is_rec = False
        if filtered:
            _, orig_idx, (sel_name, sel_count, sel_skills) = filtered[cur]
            sel_is_rec = (orig_idx == recommended)

        def s(r, c, text, attr=0):
            try:
                if 0 <= r < h and 0 <= c < w:
                    stdscr.addstr(r, c, text[:max(0, w - c - 1)], attr)
            except curses.error:
                pass

        def hline_full(r):
            """Header row — left + right border only, no center divider."""
            s(r, bx, "│", BORDER)
            s(r, bx + bw - 1, "│", BORDER)

        def hline(r):
            """Content row — left border, center divider, right border."""
            s(r, bx, "│", BORDER)
            if not compact:
                s(r, bx + left_w, "│", BORDER)
            s(r, bx + bw - 1, "│", BORDER)

        row = 0

        try:
            # ═══ TOP BORDER ═══
            s(row, bx, "╭" + "─" * (bw - 2) + "╮", BORDER)
            row += 1

            # ═══ BREATHING SPACE ═══
            hline_full(row); row += 1
            hline_full(row); row += 1

            # ═══ CLAWD × BRAND ═══
            for ci, cl in enumerate(clawd):
                hline_full(row)
                offset = (clawd_w - len(cl)) // 2
                s(row, bx + 5 + offset, cl, ORANGE)
                if ci == 1:
                    bpos = bx + 5 + clawd_w + 3
                    s(row, bpos, "×", DIM)
                    s(row, bpos + 2, "S K I L L N O T E", ACCENT)
                row += 1

            # ═══ BREATHING SPACE ═══
            hline_full(row); row += 1
            hline_full(row); row += 1

            # ═══ SEPARATOR with stats ═══
            stats = f" ● {total_skills} skills · {len(items)} collections "
            left_inner = left_w - 1
            left_part = "├" + (stats + "─" * max(0, left_inner - len(stats)))[:left_inner]
            if compact:
                right_part = "─" * (bw - left_w - 1) + "┤"
            else:
                right_part = "┬" + "─" * max(0, right_w - 1) + "┤"
            sep = left_part + right_part
            s(row, bx, sep[:bw], BORDER)
            s(row, bx + 2, "●", GREEN)
            s(row, bx + 4, f"{total_skills} skills · {len(items)} collections", DIM)
            row += 1

            content_top = row

            # ═══ LEFT PANEL: search + list ═══

            # Breathing space
            hline(row); row += 1

            # Search box
            hline(row)
            search_w = left_w - 8
            s(row, bx + 3, "╭" + "─" * search_w + "╮", DIM)
            row += 1

            hline(row)
            s(row, bx + 3, "│", DIM)
            s(row, bx + 3 + search_w + 1, "│", DIM)
            if search:
                s(row, bx + 5, search[:search_w - 2], BOLD)
                cpos = bx + 5 + min(len(search), search_w - 2)
                s(row, cpos, " ", curses.A_REVERSE)
            else:
                s(row, bx + 5, "type to search...", DIM)
            row += 1

            hline(row)
            s(row, bx + 3, "╰" + "─" * search_w + "╯", DIM)
            row += 1

            # Breathing space
            hline(row); row += 1

            # List with Claude Code scroll indicators
            list_top = row
            list_h = h - row - footer_h - 1
            visible_count = _clamp(list_h, MIN_VISIBLE, len(filtered) if filtered else MIN_VISIBLE)

            window_start = _clamp(cur - visible_count + 1, 0, max(0, len(filtered) - visible_count))
            visible = filtered[window_start:window_start + visible_count]

            for vi, (sorted_idx, orig_idx, (name, count, skills)) in enumerate(visible):
                if row >= h - footer_h - 1:
                    break
                fi = window_start + vi
                is_focused = (fi == cur)
                is_rec = (orig_idx == recommended)
                at_top = (vi == 0 and window_start > 0)
                at_bot = (vi == len(visible) - 1 and window_start + visible_count < len(filtered))

                hline(row)

                # Indicator (Claude Code ListItem pattern)
                if is_focused:
                    s(row, bx + 3, "❯", ACCENT)
                elif at_top:
                    s(row, bx + 3, "↑", DIM)
                elif at_bot:
                    s(row, bx + 3, "↓", DIM)

                # Number + name
                num = f"{fi + 1}."
                s(row, bx + 5, num, DIM)
                nx = bx + 5 + len(num) + 1
                if is_focused:
                    s(row, nx, name, ACCENT)
                else:
                    s(row, nx, name, DIM if not is_rec else 0)
                if is_rec:
                    s(row, nx + len(name) + 1, "★", YELLOW | (0 if is_focused else DIM))

                cnt = str(count)
                s(row, bx + left_w - len(cnt) - 2, cnt, DIM)
                row += 1

            # Pad remaining left rows
            while row < h - footer_h - 1:
                hline(row)
                row += 1

            # ═══ RIGHT PANEL: preview ═══
            if not compact and sel_skills:
                rr = content_top

                # Empty line
                rr += 1

                # Header
                header = sel_name
                if sel_is_rec:
                    header += " ★"
                if focus == "right":
                    s(rr, bx + left_w + 3, "❯ " + header, ACCENT)
                else:
                    s(rr, bx + left_w + 4, header, BOLD)
                cnt_txt = f"{sel_count} skills"
                s(rr, bx + bw - len(cnt_txt) - 2, cnt_txt, DIM)
                rr += 1

                # Separator
                s(rr, bx + left_w + 4, "─" * (right_w - 6), DIM)
                rr += 1

                rr += 1  # gap

                # Skill list with word-wrapped descriptions
                desc_w = right_w - 8
                skills_shown = 0
                skill_list = sel_skills[right_scroll:]
                for si, (slug, desc) in enumerate(skill_list):
                    real_idx = si + right_scroll
                    if rr >= h - footer_h - 2:
                        break

                    # Number + skill name
                    num = f"{real_idx + 1}."
                    s(rr, bx + left_w + 4, num, DIM)
                    s(rr, bx + left_w + 4 + len(num) + 1, slug, curses.color_pair(1))
                    rr += 1
                    skills_shown += 1

                    # Description (stripped of triggers, word-wrapped)
                    clean_desc = _strip_trigger(desc)
                    if clean_desc and rr < h - footer_h - 2:
                        for dl in _wrap(clean_desc, desc_w):
                            if rr >= h - footer_h - 2:
                                break
                            s(rr, bx + left_w + 8, dl, DIM)
                            rr += 1

                    # Gap between skills
                    if rr < h - footer_h - 2:
                        rr += 1

                # Scroll info
                last = right_scroll + skills_shown
                if right_scroll > 0 or last < len(sel_skills):
                    info = f"{right_scroll + 1}-{last} of {len(sel_skills)}"
                    arrows = ""
                    if right_scroll > 0:
                        arrows += "↑ "
                    if last < len(sel_skills):
                        arrows += "↓"
                    s(rr, bx + left_w + 4, info, DIM)
                    s(rr, bx + bw - len(arrows) - 2, arrows, DIM)

            # ═══ BOTTOM BORDER with hints + links ═══
            bot_row = h - 1
            s(bot_row, bx, "╰" + "─" * (bw - 2) + "╯", BORDER)
            hints = " ↑/↓ navigate · Enter select · Tab panel · Esc cancel "
            s(bot_row, bx + 2, hints, DIM)
            links = f" {web_url} · {gh_url} ★ "
            s(bot_row, bx + bw - len(links) - 1, links, DIM | curses.color_pair(1))

        except curses.error:
            pass

        stdscr.refresh()

        # ═══ KEYS ═══
        key = stdscr.getch()
        if key == 9:  # Tab
            focus = "right" if focus == "left" else "left"
        elif key == curses.KEY_UP:
            if focus == "left":
                if cur > 0:
                    cur -= 1
                    right_scroll = 0
            else:
                if right_scroll > 0:
                    right_scroll -= 1
        elif key == curses.KEY_DOWN:
            if focus == "left":
                if filtered and cur < len(filtered) - 1:
                    cur += 1
                    right_scroll = 0
            else:
                if sel_skills and right_scroll < len(sel_skills) - 1:
                    right_scroll += 1
        elif key == curses.KEY_LEFT:
            focus = "left"
        elif key == curses.KEY_RIGHT:
            focus = "right"
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if filtered:
                _, orig_idx, _ = filtered[cur]
                return [items[orig_idx][0]]
        elif key in (ord("q"), 27):
            return None
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            search = search[:-1]
            cur = 0
            right_scroll = 0
            focus = "left"
        elif 32 <= key <= 126:
            search += chr(key)
            cur = 0
            right_scroll = 0
            focus = "left"


def pick_fallback(items, recommended=0):
    print("\n ✦ S K I L L N O T E — Pick a collection\n")
    order = [recommended] + [i for i in range(len(items)) if i != recommended]
    for pos, i in enumerate(order):
        name, count, skills = items[i]
        rec = " ★" if i == recommended else ""
        print(f"  {pos + 1}. {name} ({count} skills){rec}")
        if skills:
            print(f"     {', '.join(s for s, _ in skills[:5])}")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[order[n - 1]][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if not os.isatty(0) or not os.isatty(1):
        return
    host, collections = fetch_collections()
    if not collections:
        print(f"  ✦ SkillNote: could not reach API at http://{host}:8082", file=sys.stderr)
        return
    if len(collections) == 1:
        name, count, _ = collections[0]
        if not os.path.isfile(".skillnote.json"):
            try:
                with open(".skillnote.json", "w") as f:
                    json.dump({"collections": [name]}, f, indent=2)
                    f.write("\n")
                _run_sync()
            except PermissionError:
                pass
        print(f"  ✦ SkillNote: {name} ({count} skills)")
        return
    recommended = _get_recommended(collections)
    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections, recommended)
    else:
        chosen = pick_fallback(collections, recommended)
    if not chosen:
        current = _get_current_collections()
        if current:
            print(f"  ✦ SkillNote: {', '.join(current)} (active)")
        return
    current = _get_current_collections()
    changed = current != chosen
    try:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
    except PermissionError:
        print("  ✦ SkillNote: cannot write .skillnote.json (permission denied)", file=sys.stderr)
        return
    if changed and current is not None:
        _clean_skills_dir()
    _run_sync()


if __name__ == "__main__":
    main()
