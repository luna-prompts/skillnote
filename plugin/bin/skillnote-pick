#!/usr/bin/env python3
"""SkillNote collection picker — Claude Code-style FuzzyPicker with two-pane preview."""
import json
import os
import re
import sys
import time
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False

# ── Constants (matching Claude Code's FuzzyPicker) ──
CHROME_ROWS = 8       # divider + brand + search(3) + hints + gaps
MIN_VISIBLE = 2       # never show fewer than 2 items
DEFAULT_VISIBLE = 8   # default list height
LEFT_MAX_W = 44       # max left panel width
LEFT_MIN_W = 28       # min left panel width
COMPACT_THRESHOLD = 70  # below this, single-column mode


def _get_host():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", ""))
    if host:
        return host
    host_file = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(host_file):
        try:
            with open(host_file) as f:
                val = f.read().strip()
            if val:
                return val
        except Exception:
            pass
    return "localhost"


def fetch_collections():
    host = _get_host()
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        collections = []
        for c in data:
            skills = []
            try:
                skill_data = json.loads(urllib.request.urlopen(
                    f"{api}/v1/skills?collections={c['name']}", timeout=3
                ).read())
                skills = [(s["slug"], s.get("description", "")) for s in skill_data]
            except Exception:
                pass
            collections.append((c["name"], c["count"], skills))
        return host, collections
    except Exception:
        return host, []


def _get_recommended(items):
    names = [n.lower() for n, _, _ in items]
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                cfg = json.load(f)
            current = cfg.get("collections", [])
            if current:
                for i, (n, _, _) in enumerate(items):
                    if n.lower() == current[0].lower():
                        return i
        except Exception:
            pass
    folder = os.path.basename(os.getcwd()).lower()
    for i, name in enumerate(names):
        if name == folder:
            return i
    return 0


def _get_current_collections():
    if os.path.isfile(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                return json.load(f).get("collections", [])
        except Exception:
            pass
    return None


def _clean_skills_dir():
    import shutil
    skills_dir = os.path.join(".claude", "skills")
    if os.path.isdir(skills_dir):
        for entry in os.listdir(skills_dir):
            path = os.path.join(skills_dir, entry)
            if os.path.isdir(path):
                shutil.rmtree(path)
            elif entry.endswith(".json"):
                os.remove(path)


def _run_sync():
    host = _get_host()
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        sync_path = os.path.join(plugin_root, "hooks-handlers", "sync.sh")
        if os.path.exists(sync_path):
            os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
            os.system(f'"{sync_path}" 2>/dev/null')
            return
    mkt_sync = os.path.expanduser(
        "~/.claude/plugins/marketplaces/skillnote-local/plugins/skillnote/hooks-handlers/sync.sh"
    )
    if os.path.exists(mkt_sync):
        os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
        os.system(f'"{mkt_sync}" 2>/dev/null')
        return
    os.system("skillnote-sync --force 2>/dev/null")


def _wrap(text, w):
    """Word-wrap text to width, max 4 lines."""
    lines = []
    while text and len(lines) < 4:
        if len(text) <= w:
            lines.append(text)
            break
        sp = text[:w].rfind(" ")
        if sp <= 0:
            sp = w
        lines.append(text[:sp])
        text = text[sp:].lstrip()
    return lines


def _clamp(val, lo, hi):
    return max(lo, min(val, hi))


def pick(stdscr, items, recommended=0):
    # Sort: recommended first
    sorted_items = []
    if 0 <= recommended < len(items):
        sorted_items.append((recommended, items[recommended]))
    for i, it in enumerate(items):
        if i != recommended:
            sorted_items.append((i, it))

    cur = 0
    search = ""
    right_scroll = 0
    focus = "left"

    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    # Claude Code color mapping
    curses.init_pair(1, curses.COLOR_CYAN, -1)     # accent / brand
    curses.init_pair(2, curses.COLOR_GREEN, -1)     # success / connected
    curses.init_pair(3, curses.COLOR_YELLOW, -1)    # warning / highlight
    curses.init_pair(4, curses.COLOR_RED, -1)       # error
    try:
        curses.init_pair(5, 208, -1)                # orange for Clawd
    except Exception:
        curses.init_pair(5, curses.COLOR_RED, -1)

    # Flush stale input
    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    time.sleep(0.15)

    total_skills = sum(c for _, c, _ in items)
    host = _get_host()
    web_url = f"http://{host}:3000"
    gh_url = "github.com/luna-prompts/skillnote"

    ACCENT = curses.color_pair(1)
    ACCENT_B = curses.color_pair(1) | curses.A_BOLD
    GREEN = curses.color_pair(2)
    YELLOW = curses.color_pair(3)
    ORANGE = curses.color_pair(5) | curses.A_BOLD
    DIM = curses.A_DIM
    BOLD = curses.A_BOLD

    clawd = ["▐▛███▜▌", "▝▜█████▛▘", "▘▘ ▝▝"]
    clawd_w = 9

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()

        # Filter
        if search:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)
                        if search.lower() in it[0].lower()]
        else:
            filtered = [(si, oi, it) for si, (oi, it) in enumerate(sorted_items)]
        if filtered:
            cur = _clamp(cur, 0, len(filtered) - 1)

        # Layout — responsive
        pad_x = 2
        full_w = w - pad_x * 2
        compact = w < COMPACT_THRESHOLD

        if compact:
            left_w = full_w
            right_w = 0
        else:
            left_w = _clamp(full_w * 2 // 5, LEFT_MIN_W, LEFT_MAX_W)
            right_w = full_w - left_w - 1  # 1 for divider │

        visible_count = _clamp(h - CHROME_ROWS, MIN_VISIBLE, DEFAULT_VISIBLE)
        if len(filtered) < visible_count:
            visible_count = max(MIN_VISIBLE, len(filtered))

        # Selected item for preview
        sel_name, sel_count, sel_skills = "", 0, []
        sel_is_rec = False
        if filtered:
            _, orig_idx, (sel_name, sel_count, sel_skills) = filtered[cur]
            sel_is_rec = (orig_idx == recommended)

        def s(r, c, text, attr=0):
            try:
                if 0 <= r < h and 0 <= c < w:
                    stdscr.addstr(r, c, text[:max(0, w - c - 1)], attr)
            except curses.error:
                pass

        row = 0
        lx = pad_x       # left panel x
        rx = pad_x + left_w + 1  # right panel x (after divider)

        try:
            # ═══ DIVIDER LINE (Pane-style) ═══
            s(row, pad_x, "─" * full_w, ACCENT | DIM)
            row += 1

            # ═══ BRAND: Clawd × S K I L L N O T E ═══
            for ci, cl in enumerate(clawd):
                offset = (clawd_w - len(cl)) // 2
                s(row, lx + 2 + offset, cl, ORANGE)
                if ci == 1:
                    bx = lx + 2 + clawd_w + 3
                    s(row, bx, "×", DIM)
                    s(row, bx + 2, "S K I L L N O T E", ACCENT_B)
                    # Right-aligned stats
                    stats = f"● {total_skills} skills · {len(items)} collections"
                    sx = pad_x + full_w - len(stats)
                    s(row, sx, "●", GREEN)
                    s(row, sx + 2, stats[2:], DIM)
                row += 1

            # Gap
            row += 1

            # ═══ SEARCH BOX (Claude-style rounded border) ═══
            search_inner_w = left_w - 4
            s(row, lx, "╭" + "─" * (search_inner_w + 2) + "╮", DIM)
            row += 1

            s(row, lx, "│", DIM)
            s(row, lx + search_inner_w + 3, "│", DIM)
            s(row, lx + 2, "⌕ ", DIM)
            if search:
                s(row, lx + 4, search[:search_inner_w - 3], BOLD)
                cpos = lx + 4 + min(len(search), search_inner_w - 3)
                s(row, cpos, " ", curses.A_REVERSE)
            else:
                s(row, lx + 4, "Search...", DIM)
            if search:
                mt = f"{len(filtered)}"
                s(row, lx + search_inner_w + 1 - len(mt), mt, DIM)
            row += 1

            s(row, lx, "╰" + "─" * (search_inner_w + 2) + "╯", DIM)
            row += 1

            # Gap
            row += 1

            # ═══ LIST + PREVIEW ═══
            list_top = row

            # Scroll calculation (Claude's exact pattern)
            window_start = _clamp(cur - visible_count + 1, 0, max(0, len(filtered) - visible_count))
            visible = filtered[window_start:window_start + visible_count]

            # Render list items (fixed height = visible_count)
            for vi, (sorted_idx, orig_idx, (name, count, skills)) in enumerate(visible):
                fi = window_start + vi
                is_focused = (fi == cur)
                is_rec = (orig_idx == recommended)
                at_top_edge = (vi == 0 and window_start > 0)
                at_bot_edge = (vi == len(visible) - 1 and window_start + visible_count < len(filtered))

                # Indicator (Claude's ListItem pattern)
                if is_focused:
                    indicator = "❯"
                    ind_attr = ACCENT_B
                elif at_top_edge:
                    indicator = "↑"
                    ind_attr = DIM
                elif at_bot_edge:
                    indicator = "↓"
                    ind_attr = DIM
                else:
                    indicator = " "
                    ind_attr = 0

                s(row, lx, indicator, ind_attr)

                # Name + count
                if is_focused:
                    s(row, lx + 2, name, ACCENT_B)
                    if is_rec:
                        s(row, lx + 2 + len(name) + 1, "★", YELLOW)
                else:
                    s(row, lx + 2, name, DIM if not is_rec else 0)
                    if is_rec:
                        s(row, lx + 2 + len(name) + 1, "★", YELLOW | DIM)
                cnt = str(count)
                s(row, lx + left_w - len(cnt) - 1, cnt, DIM)

                # Divider between panels
                if not compact:
                    s(row, rx - 1, "│", DIM)

                row += 1

            # Pad remaining list rows to fixed height
            while row < list_top + visible_count:
                if not compact:
                    s(row, rx - 1, "│", DIM)
                row += 1

            # Match count below list
            if search and filtered:
                s(row, lx + 2, f"{len(filtered)} match{'es' if len(filtered) != 1 else ''}", DIM)
            elif not filtered and search:
                s(row, lx + 2, "No results", DIM)
            row += 1

            # ═══ RIGHT PANEL (Preview) ═══
            if not compact and sel_skills:
                pr = list_top

                # Header
                header = sel_name
                if sel_is_rec:
                    header += " ★"
                if focus == "right":
                    s(pr, rx + 1, "❯ " + header, ACCENT_B)
                else:
                    s(pr, rx + 1, header, BOLD)
                cnt_txt = f"{sel_count} skills"
                s(pr, pad_x + full_w - len(cnt_txt), cnt_txt, DIM)
                pr += 1

                # Separator
                s(pr, rx + 1, "─" * (right_w - 2), DIM)
                pr += 1

                pr += 1  # gap

                # Skills (scrollable, word-wrapped)
                desc_w = right_w - 6
                skills_shown = 0
                skill_list = sel_skills[right_scroll:]
                for si, (slug, desc) in enumerate(skill_list):
                    real_idx = si + right_scroll
                    if pr >= list_top + visible_count - 1:
                        break

                    s(pr, rx + 1, f"{real_idx + 1}.", DIM)
                    s(pr, rx + 1 + len(str(real_idx + 1)) + 2, slug, ACCENT)
                    pr += 1
                    skills_shown += 1

                    if desc and pr < list_top + visible_count - 1:
                        for dl in _wrap(desc, desc_w):
                            if pr >= list_top + visible_count - 1:
                                break
                            s(pr, rx + 5, dl, DIM)
                            pr += 1

                    if pr < list_top + visible_count - 1:
                        pr += 1  # gap

                # Scroll info
                if right_scroll > 0 or (right_scroll + skills_shown) < len(sel_skills):
                    last = min(right_scroll + skills_shown, len(sel_skills))
                    info = f"{right_scroll + 1}-{last} of {len(sel_skills)}"
                    arrows = ""
                    if right_scroll > 0:
                        arrows += "↑ "
                    if last < len(sel_skills):
                        arrows += "↓"
                    info_row = list_top + visible_count
                    s(info_row, rx + 1, info, DIM)
                    s(info_row, pad_x + full_w - len(arrows), arrows, DIM)

                # Fill divider for remaining rows
                for fr in range(list_top, list_top + visible_count + 1):
                    s(fr, rx - 1, "│", DIM)

            # ═══ HINTS (Byline-style) ═══
            hint_row = list_top + visible_count + 2
            if hint_row >= h:
                hint_row = h - 1

            hints_parts = ["↑/↓ navigate", "Enter select"]
            if not compact:
                hints_parts.append("Tab panel")
            hints_parts.append("Esc cancel")
            hints = " · ".join(hints_parts)
            s(hint_row, lx, hints, DIM)

            # Right-aligned links
            links = f"{web_url} · {gh_url} ★"
            s(hint_row, pad_x + full_w - len(links), links, DIM | ACCENT)

        except curses.error:
            pass

        stdscr.refresh()

        # ═══ KEY HANDLING ═══
        key = stdscr.getch()
        if key == 9:  # Tab
            focus = "right" if focus == "left" else "left"
        elif key == curses.KEY_UP:
            if focus == "left":
                if cur > 0:
                    cur -= 1
                    right_scroll = 0
            else:
                if right_scroll > 0:
                    right_scroll -= 1
        elif key == curses.KEY_DOWN:
            if focus == "left":
                if filtered and cur < len(filtered) - 1:
                    cur += 1
                    right_scroll = 0
            else:
                max_rs = max(0, len(sel_skills) - 1)
                if right_scroll < max_rs:
                    right_scroll += 1
        elif key == curses.KEY_LEFT:
            focus = "left"
        elif key == curses.KEY_RIGHT:
            focus = "right"
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            if filtered:
                _, orig_idx, _ = filtered[cur]
                return [items[orig_idx][0]]
        elif key in (ord("q"), 27):  # q or Esc
            return None
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            search = search[:-1]
            cur = 0
            right_scroll = 0
            focus = "left"
        elif 32 <= key <= 126:
            search += chr(key)
            cur = 0
            right_scroll = 0
            focus = "left"


def pick_fallback(items, recommended=0):
    print("\n ✦ S K I L L N O T E — Pick a collection\n")
    order = [recommended] + [i for i in range(len(items)) if i != recommended]
    for pos, i in enumerate(order):
        name, count, skills = items[i]
        rec = " ★" if i == recommended else ""
        print(f"  {pos + 1}. {name} ({count} skills){rec}")
        if skills:
            print(f"     {', '.join(s for s, _ in skills[:5])}")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[order[n - 1]][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if not os.isatty(0) or not os.isatty(1):
        return

    host, collections = fetch_collections()

    if not collections:
        print(f"  ✦ SkillNote: could not reach API at http://{host}:8082", file=sys.stderr)
        return

    if len(collections) == 1:
        name, count, _ = collections[0]
        if not os.path.isfile(".skillnote.json"):
            try:
                with open(".skillnote.json", "w") as f:
                    json.dump({"collections": [name]}, f, indent=2)
                    f.write("\n")
                _run_sync()
            except PermissionError:
                pass
        print(f"  ✦ SkillNote: {name} ({count} skills)")
        return

    recommended = _get_recommended(collections)

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections, recommended)
    else:
        chosen = pick_fallback(collections, recommended)

    if not chosen:
        current = _get_current_collections()
        if current:
            print(f"  ✦ SkillNote: {', '.join(current)} (active)")
        return

    current = _get_current_collections()
    changed = current != chosen

    try:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
    except PermissionError:
        print("  ✦ SkillNote: cannot write .skillnote.json (permission denied)", file=sys.stderr)
        return

    if changed and current is not None:
        _clean_skills_dir()

    _run_sync()


if __name__ == "__main__":
    main()
