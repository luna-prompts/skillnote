#!/usr/bin/env python3
"""SkillNote collection picker Рђћ minimal terminal UI."""
import json
import os
import sys
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def fetch_collections():
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        return [(c["name"], c["count"]) for c in data]
    except Exception:
        return []


def pick(stdscr, items):
    cur = 0
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_WHITE, -1)
    curses.init_pair(4, curses.COLOR_YELLOW, -1)

    # Flush stale input (the Enter from typing 'claude')
    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    import time
    time.sleep(0.15)

    total_skills = sum(c for _, c in items)
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", "localhost"))
    web_url = f"http://{host}:3000"

    brand = [
        "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЌ  РќѕРќѕРЋЌРќѕРќѕРЋЌРќѕРќѕРЋЌ     РќѕРќѕРЋЌ     РќѕРќѕРќѕРЋЌ   РќѕРќѕРЋЌ РќѕРќѕРќѕРќѕРќѕРќѕРЋЌ РќѕРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ",
        "РќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРЋЉ РќѕРќѕРЋћРЋЮРќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРќѕРќѕРЋЌ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРЋљРќѕРќѕРЋЌРЋџРЋљРЋљРќѕРќѕРЋћРЋљРЋљРЋЮРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮ",
        "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРЋћРЋЮ РќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРЋћРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРќѕРќѕРќѕРЋЌ  ",
        "РЋџРЋљРЋљРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋћРЋљРќѕРќѕРЋЌ РќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋЉ     РќѕРќѕРЋЉРЋџРќѕРќѕРЋЌРќѕРќѕРЋЉРќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋћРЋљРЋљРЋЮ  ",
        "РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРЋЉ  РќѕРќѕРЋЌРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЉ РЋџРќѕРќѕРќѕРќѕРЋЉРЋџРќѕРќѕРќѕРќѕРќѕРќѕРЋћРЋЮ   РќѕРќѕРЋЉ   РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЌ",
        "РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋЮРЋџРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋљРЋљРЋЮ РЋџРЋљРЋљРЋљРЋљРЋљРЋЮ    РЋџРЋљРЋЮ   РЋџРЋљРЋљРЋљРЋљРЋљРЋљРЋЮ",
    ]

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        row = 1

        cw = min(w - 4, 76)   # content width
        mx = (w - cw) // 2    # left margin

        def ctr_x(text):
            return mx + max(0, cw - len(text)) // 2

        try:
            # РћђРћђ Brand РћђРћђ
            brand_w = len(brand[0])
            if cw >= brand_w:
                for bl in brand:
                    stdscr.addstr(row, ctr_x(bl), bl, curses.A_BOLD | curses.color_pair(1))
                    row += 1
            else:
                t = "S K I L L N O T E"
                stdscr.addstr(row, ctr_x(t), t, curses.A_BOLD | curses.color_pair(1))
                row += 1
            row += 1

            # РћђРћђ Tagline + info РћђРћђ
            tag = "Reusable skills for AI coding agents"
            stdscr.addstr(row, ctr_x(tag), tag, curses.A_DIM)
            row += 1
            info = f"{total_skills} skills ┬и {len(items)} collections ┬и {web_url}"
            stdscr.addstr(row, ctr_x(info), info, curses.A_DIM)
            row += 2

            # РћђРћђ Rule РћђРћђ
            stdscr.addstr(row, mx, "Рћђ" * cw, curses.color_pair(1) | curses.A_DIM)
            row += 2

            # РћђРћђ Prompt РћђРћђ
            stdscr.addstr(row, mx + 2, "Pick a collection for this project:", curses.A_BOLD)
            row += 2

            # РћђРћђ Items РћђРћђ
            for i, (name, count) in enumerate(items):
                if row >= h - 6:
                    break
                if i == cur:
                    stdscr.addstr(row, mx + 4, "РЮ» ", curses.color_pair(1) | curses.A_BOLD)
                    stdscr.addstr(name, curses.A_BOLD)
                    stdscr.addstr(f"  {count} skills", curses.A_DIM)
                else:
                    stdscr.addstr(row, mx + 4, "  ")
                    stdscr.addstr(name, curses.A_DIM)
                    stdscr.addstr(f"  {count} skills", curses.A_DIM)
                row += 1
            row += 2

            # РћђРћђ Rule РћђРћђ
            if row < h - 4:
                stdscr.addstr(row, mx, "Рћђ" * cw, curses.color_pair(1) | curses.A_DIM)
                row += 2

            # РћђРћђ Browse link РћђРћђ
            if row < h - 2:
                stdscr.addstr(row, mx + 2, "Browse all Рєњ ", curses.A_DIM)
                stdscr.addstr(f"{web_url}/collections", curses.color_pair(1))
                row += 2

            # РћђРћђ Hints РћђРћђ
            hints = "РєЉ/РєЊ move ┬и Enter select ┬и q skip"
            stdscr.addstr(min(row, h - 1), mx + 2, hints, curses.A_DIM)

        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP and cur > 0:
            cur -= 1
        elif key == curses.KEY_DOWN and cur < len(items) - 1:
            cur += 1
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            return [items[cur][0]]
        elif key in (ord("q"), 27):
            return None


def pick_fallback(items):
    print("\n  SkillNote Рђћ Pick a collection for this project\n")
    for i, (name, count) in enumerate(items, 1):
        print(f"  {i}. {name} ({count} skills)")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[n - 1][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if os.path.exists(".skillnote.json"):
        return
    if not os.isatty(0) or not os.isatty(1):
        return

    collections = fetch_collections()
    if len(collections) <= 1:
        return

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections)
    else:
        chosen = pick_fallback(collections)

    if not chosen:
        return

    with open(".skillnote.json", "w") as f:
        json.dump({"collections": chosen}, f, indent=2)
        f.write("\n")
    names = ", ".join(chosen)
    total = sum(c for n, c in collections if n in chosen)
    print(f"\n  SkillNote: {names} ({total} skills)\n")

    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        os.system(f'"{plugin_root}/hooks-handlers/sync.sh" 2>/dev/null')
    else:
        os.system("skillnote-sync --force 2>/dev/null")


if __name__ == "__main__":
    main()
