#!/usr/bin/env python3
"""SkillNote collection picker тАФ minimal terminal UI."""
import json
import os
import sys
import time
import urllib.request

try:
    import curses
    HAS_CURSES = True
except ImportError:
    HAS_CURSES = False


def _get_host():
    """Resolve SkillNote API host. Check env, then ~/.skillnote/host file."""
    host = os.environ.get("SKILLNOTE_HOST", os.environ.get("CLAUDE_PLUGIN_OPTION_HOST", ""))
    if host:
        return host
    host_file = os.path.expanduser("~/.skillnote/host")
    if os.path.exists(host_file):
        try:
            with open(host_file) as f:
                val = f.read().strip()
            if val:
                return val
        except Exception:
            pass
    return "localhost"


def fetch_collections():
    host = _get_host()
    api = f"http://{host}:8082"
    try:
        data = json.loads(urllib.request.urlopen(f"{api}/v1/collections", timeout=3).read())
        return host, [(c["name"], c["count"]) for c in data]
    except Exception:
        return host, []


def _get_recommended(items):
    """Return index of recommended collection: from .skillnote.json or folder name match."""
    names = [n.lower() for n, _ in items]

    # 1. Current .skillnote.json
    if os.path.exists(".skillnote.json"):
        try:
            with open(".skillnote.json") as f:
                cfg = json.load(f)
            current = cfg.get("collections", [])
            if current:
                for i, (n, _) in enumerate(items):
                    if n.lower() == current[0].lower():
                        return i
        except Exception:
            pass

    # 2. Folder name match (exact only тАФ consistent with sync.sh)
    folder = os.path.basename(os.getcwd()).lower()
    for i, name in enumerate(names):
        if name == folder:
            return i

    return 0


def _run_sync():
    """Run sync using the best available path."""
    host = _get_host()
    # Try plugin root first (set during Claude sessions)
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        sync_path = os.path.join(plugin_root, "hooks-handlers", "sync.sh")
        if os.path.exists(sync_path):
            os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
            os.system(f'"{sync_path}" 2>/dev/null')
            return

    # Try installed plugin in marketplace
    mkt_sync = os.path.expanduser(
        "~/.claude/plugins/marketplaces/skillnote-local/plugins/skillnote/hooks-handlers/sync.sh"
    )
    if os.path.exists(mkt_sync):
        os.environ.setdefault("CLAUDE_PLUGIN_OPTION_HOST", host)
        os.system(f'"{mkt_sync}" 2>/dev/null')
        return

    # Try skillnote-sync in PATH as last resort
    os.system("skillnote-sync --force 2>/dev/null")


def pick(stdscr, items, recommended=0):
    cur = recommended
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_GREEN, -1)
    curses.init_pair(3, curses.COLOR_WHITE, -1)
    curses.init_pair(4, curses.COLOR_YELLOW, -1)

    # Flush stale input (the Enter from typing 'claude')
    curses.flushinp()
    stdscr.nodelay(True)
    while stdscr.getch() != -1:
        pass
    stdscr.nodelay(False)
    time.sleep(0.15)

    total_skills = sum(c for _, c in items)
    host = _get_host()
    web_url = f"http://{host}:3000"

    brand = [
        "тЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧтЦИтЦИтХЧ  тЦИтЦИтХЧтЦИтЦИтХЧтЦИтЦИтХЧ     тЦИтЦИтХЧ     тЦИтЦИтЦИтХЧ   тЦИтЦИтХЧ тЦИтЦИтЦИтЦИтЦИтЦИтХЧ тЦИтЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧтЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧ",
        "тЦИтЦИтХФтХРтХРтХРтХРтХЭтЦИтЦИтХС тЦИтЦИтХФтХЭтЦИтЦИтХСтЦИтЦИтХС     тЦИтЦИтХС     тЦИтЦИтЦИтЦИтХЧ  тЦИтЦИтХСтЦИтЦИтХФтХРтХРтХРтЦИтЦИтХЧтХЪтХРтХРтЦИтЦИтХФтХРтХРтХЭтЦИтЦИтХФтХРтХРтХРтХРтХЭ",
        "тЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧтЦИтЦИтЦИтЦИтЦИтХФтХЭ тЦИтЦИтХСтЦИтЦИтХС     тЦИтЦИтХС     тЦИтЦИтХФтЦИтЦИтХЧ тЦИтЦИтХСтЦИтЦИтХС   тЦИтЦИтХС   тЦИтЦИтХС   тЦИтЦИтЦИтЦИтЦИтХЧ  ",
        "тХЪтХРтХРтХРтХРтЦИтЦИтХСтЦИтЦИтХФтХРтЦИтЦИтХЧ тЦИтЦИтХСтЦИтЦИтХС     тЦИтЦИтХС     тЦИтЦИтХСтХЪтЦИтЦИтХЧтЦИтЦИтХСтЦИтЦИтХС   тЦИтЦИтХС   тЦИтЦИтХС   тЦИтЦИтХФтХРтХРтХЭ  ",
        "тЦИтЦИтЦИтЦИтЦИтЦИтЦИтХСтЦИтЦИтХС  тЦИтЦИтХЧтЦИтЦИтХСтЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧтЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧтЦИтЦИтХС тХЪтЦИтЦИтЦИтЦИтХСтХЪтЦИтЦИтЦИтЦИтЦИтЦИтХФтХЭ   тЦИтЦИтХС   тЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧ",
        "тХЪтХРтХРтХРтХРтХРтХРтХЭтХЪтХРтХЭ  тХЪтХРтХЭтХЪтХРтХЭтХЪтХРтХРтХРтХРтХРтХРтХЭтХЪтХРтХРтХРтХРтХРтХРтХЭтХЪтХРтХЭ  тХЪтХРтХРтХРтХЭ тХЪтХРтХРтХРтХРтХРтХЭ    тХЪтХРтХЭ   тХЪтХРтХРтХРтХРтХРтХРтХЭ",
    ]

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        row = 1

        cw = min(w - 4, 76)
        mx = (w - cw) // 2

        def ctr_x(text):
            return mx + max(0, cw - len(text)) // 2

        try:
            # тФАтФА Brand тФАтФА
            brand_w = len(brand[0])
            if cw >= brand_w:
                for bl in brand:
                    stdscr.addstr(row, ctr_x(bl), bl, curses.A_BOLD | curses.color_pair(1))
                    row += 1
            else:
                t = "S K I L L N O T E"
                stdscr.addstr(row, ctr_x(t), t, curses.A_BOLD | curses.color_pair(1))
                row += 1
            row += 1

            # тФАтФА Tagline + info тФАтФА
            tag = "Reusable skills for AI coding agents"
            stdscr.addstr(row, ctr_x(tag), tag, curses.A_DIM)
            row += 1
            info = f"{total_skills} skills ┬╖ {len(items)} collections ┬╖ {web_url}"
            stdscr.addstr(row, ctr_x(info), info, curses.A_DIM)
            row += 2

            # тФАтФА Rule тФАтФА
            stdscr.addstr(row, mx, "тФА" * cw, curses.color_pair(1) | curses.A_DIM)
            row += 2

            # тФАтФА Prompt тФАтФА
            stdscr.addstr(row, mx + 2, "Pick a collection for this project:", curses.A_BOLD)
            row += 2

            # тФАтФА Items тФАтФА
            for i, (name, count) in enumerate(items):
                if row >= h - 6:
                    break
                is_rec = (i == recommended)
                if i == cur:
                    stdscr.addstr(row, mx + 4, "тЭп ", curses.color_pair(1) | curses.A_BOLD)
                    stdscr.addstr(name, curses.A_BOLD)
                    stdscr.addstr(f"  {count} skills", curses.A_DIM)
                    if is_rec:
                        stdscr.addstr("  тШЕ recommended", curses.color_pair(4))
                else:
                    stdscr.addstr(row, mx + 4, "  ")
                    stdscr.addstr(name, curses.A_DIM)
                    stdscr.addstr(f"  {count} skills", curses.A_DIM)
                    if is_rec:
                        stdscr.addstr("  тШЕ", curses.color_pair(4) | curses.A_DIM)
                row += 1
            row += 2

            # тФАтФА Rule тФАтФА
            if row < h - 4:
                stdscr.addstr(row, mx, "тФА" * cw, curses.color_pair(1) | curses.A_DIM)
                row += 2

            # тФАтФА Browse link тФАтФА
            if row < h - 2:
                stdscr.addstr(row, mx + 2, "Browse all тЖТ ", curses.A_DIM)
                stdscr.addstr(f"{web_url}/collections", curses.color_pair(1))
                row += 2

            # тФАтФА Hints тФАтФА
            hints = "тЖС/тЖУ move ┬╖ Enter select ┬╖ q keep current"
            stdscr.addstr(min(row, h - 1), mx + 2, hints, curses.A_DIM)

        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == curses.KEY_UP and cur > 0:
            cur -= 1
        elif key == curses.KEY_DOWN and cur < len(items) - 1:
            cur += 1
        elif key in (ord("\n"), curses.KEY_ENTER, 10, 13):
            return [items[cur][0]]
        elif key in (ord("q"), 27):
            return None


def pick_fallback(items, recommended=0):
    print("\n  SkillNote тАФ Pick a collection for this project")
    print("  Enter number to select, q to keep current\n")
    for i, (name, count) in enumerate(items, 1):
        rec = " тШЕ recommended" if i - 1 == recommended else ""
        print(f"  {i}. {name} ({count} skills){rec}")
    print()
    try:
        reply = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if reply.lower() == "q" or not reply:
        return None
    try:
        n = int(reply)
        if 1 <= n <= len(items):
            return [items[n - 1][0]]
    except (ValueError, IndexError):
        pass
    return None


def main():
    if not os.isatty(0) or not os.isatty(1):
        return

    host, collections = fetch_collections()

    if not collections:
        print(f"  SkillNote: could not reach API at http://{host}:8082", file=sys.stderr)
        return

    # Single collection: auto-select, no picker needed
    if len(collections) == 1:
        name, count = collections[0]
        if not os.path.exists(".skillnote.json"):
            try:
                with open(".skillnote.json", "w") as f:
                    json.dump({"collections": [name]}, f, indent=2)
                    f.write("\n")
                _run_sync()
            except PermissionError:
                pass
        print(f"  SkillNote: {name} ({count} skills)")
        return

    recommended = _get_recommended(collections)

    if HAS_CURSES:
        chosen = curses.wrapper(pick, collections, recommended)
    else:
        chosen = pick_fallback(collections, recommended)

    if not chosen:
        # q pressed тАФ keep current config if exists
        if os.path.exists(".skillnote.json"):
            try:
                with open(".skillnote.json") as f:
                    cfg = json.load(f)
                names = ", ".join(cfg.get("collections", []))
                print(f"  SkillNote: {names} (active)")
            except Exception:
                pass
        return

    try:
        with open(".skillnote.json", "w") as f:
            json.dump({"collections": chosen}, f, indent=2)
            f.write("\n")
    except PermissionError:
        print("  SkillNote: cannot write .skillnote.json (permission denied)", file=sys.stderr)
        return

    names = ", ".join(chosen)
    total = sum(c for n, c in collections if n in chosen)
    print(f"\n  SkillNote: {names} ({total} skills)\n")

    _run_sync()


if __name__ == "__main__":
    main()
